# Server Configuration
# These are set by the server operator, NOT by end users.
# Users just visit the site and click "Connect with Strava".

# Flask session encryption - MUST be changed for production
SECRET_KEY=change-this-to-a-random-secret-key

# Strava API credentials - Pre-configured by the server operator
# Create your Strava API app at https://www.strava.com/settings/api
# These are shared by all users of this instance
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret

# Must match the "Authorization Callback Domain" in your Strava API settings
STRAVA_REDIRECT_URI=http://localhost:5000/auth/callback
